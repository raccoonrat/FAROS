# API Configuration
# Set to 'false' to use real backend
VITE_USE_MOCK=true

# Backend URL — leave empty in local dev (Vite proxies /api to http://127.0.0.1:8005).
# Only set this for production builds or when the frontend is served separately from the backend.
# VITE_API_BASE_URL=

# Optional API key for backend authentication
# VITE_API_KEY=your_api_key_here

# Development
VITE_ENABLE_DEV_TOOLS=true
